#version 450

// Top-n_used expert selection + weight computation, one workgroup.
// Selection by raw logit (softmax is monotonic); weights are the softmax over
// the selected logits only — the full-softmax denominator cancels under
// llama.cpp's norm_w renormalization. Also computes the shared-expert
// sigmoid gate: wShared = sigmoid(gate_inp_shexp · x).
// Sized for n_expert <= 512 (Qwen3-Next-80B) and n_used <= 16.

layout(local_size_x = 512) in;

layout(std430, binding = 0) readonly buffer BufL   { float logits[]; };
layout(std430, binding = 1) readonly buffer BufGIS { float gis[]; };
layout(std430, binding = 2) readonly buffer BufX   { float x[]; };
struct SelT { uint ids[16]; float w[16]; float wShared; float pad[7]; };
layout(std430, binding = 3) buffer Sel { SelT sel[]; };

layout(push_constant) uniform PC { uint n_embd; uint n_ff; uint n_expert; uint n_used; } pc;

shared float sl[512];
shared float red[512];
shared uint  redi[512];

void main() {
    uint t = gl_LocalInvocationID.x;
    uint rq = gl_WorkGroupID.z;

    // Sanitize: a NaN/Inf router logit (numerical blowup deep into a long
    // prefill) must not win the argmax below — otherwise a padding lane
    // (t >= n_expert) can be selected and yield an out-of-range expert id, an
    // OOB expert-weight read, and a GPU page fault. Map non-finite logits to
    // the padding floor so real experts always win ties over padding lanes.
    float lv = t < pc.n_expert ? logits[rq * pc.n_expert + t] : -3.4e38;
    sl[t] = (isnan(lv) || isinf(lv)) ? -3.4e38 : lv;

    // shared-expert gate dot
    float sacc = 0.0;
    for (uint k = t; k < pc.n_embd; k += 512u) sacc += gis[k] * x[rq * pc.n_embd + k];
    red[t] = sacc;
    barrier();
    for (uint s = 256u; s > 0u; s >>= 1u) {
        if (t < s) red[t] += red[t + s];
        barrier();
    }
    if (t == 0u) sel[rq].wShared = 1.0 / (1.0 + exp(-red[0]));
    barrier();

    // top-n_used by logit: n_used rounds of parallel argmax
    for (uint i = 0u; i < pc.n_used; ++i) {
        red[t] = sl[t];
        redi[t] = t;
        barrier();
        for (uint s = 256u; s > 0u; s >>= 1u) {
            if (t < s && red[t + s] > red[t]) {
                red[t] = red[t + s];
                redi[t] = redi[t + s];
            }
            barrier();
        }
        if (t == 0u) {
            // Clamp: guarantee a valid expert id even if the argmax degenerated
            // (all-nonfinite logits) and a padding lane slipped through.
            uint id = min(redi[0], pc.n_expert - 1u);
            sel[rq].ids[i] = id;
            sel[rq].w[i] = red[0];          // logit for now, softmaxed below
            sl[redi[0]] = -3.4e38;
        }
        barrier();
    }

    if (t == 0u) {
        float m = sel[rq].w[0];             // first pick has the max logit
        float sum = 0.0;
        for (uint i = 0u; i < pc.n_used; ++i) { sel[rq].w[i] = exp(sel[rq].w[i] - m); sum += sel[rq].w[i]; }
        for (uint i = 0u; i < pc.n_used; ++i) sel[rq].w[i] /= sum;
    }
}
